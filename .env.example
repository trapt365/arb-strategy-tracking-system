# Environment
NODE_ENV=development
LOG_LEVEL=info
PORT=3000
TZ=Asia/Almaty

# Anthropic Claude API
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=8192
CLAUDE_TIMEOUT_MS=120000

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_WORK_ID=
TELEGRAM_CHAT_OPS_ID=

# Ops (Story 1.9) — пустая строка = без эскалации в @mention; '@username' = ping Айдару через 24ч down
OPS_AIDAR_MENTION=

# Soniox (transcription)
SONIOX_API_KEY=

# Google Sheets
GOOGLE_SERVICE_ACCOUNT_JSON=./data/google-service-account.json

# Google Sheets — F0 (stakeholder map, OKR, F5 metrics)
GEONLINE_F0_SHEET_ID=

# Telegram bot — Story 1.5: comma-separated chat IDs трекеров (whitelist для /report)
TELEGRAM_TRACKER_CHAT_IDS=

# Bot tuning (опционально, имеют дефолты)
F1_PROGRESS_UPDATES_ENABLED=true
F1_QUEUE_MAX_SIZE=20

# Story 7.4: F0 онбординг → создание Google Sheets по шаблону v2.0
# fileId эталонного spreadsheet «Стратегический трекинг v2.0» (загрузи xlsx в Drive как Google Sheet).
# Пусто = автосоздание таблицы выключено.
F0_SHEETS_TEMPLATE_ID=
# Кому выдать writer-доступ к созданной таблице (comma-separated e-mail'ы трекера).
F0_SHEETS_SHARE_EMAILS=
# Необязательная папка Drive для копии (иначе — корень Drive сервис-аккаунта / Shared Drive).
F0_SHEETS_FOLDER_ID=

# OAuth пользователя для write-операций Drive/Sheets. Нужен, т.к. сервис-аккаунт не может
# владеть Drive-файлами (403 storage quota). Заданы все три → copy/запись идут от имени
# пользователя. Создай OAuth client «Desktop app» (Google Cloud Console), затем получи
# refresh token: npx tsx scripts/google-oauth-setup.ts
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
