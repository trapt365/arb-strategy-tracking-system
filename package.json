{
  "name": "strategy-tracking-system",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "soniox:test": "tsx scripts/soniox-test.ts",
    "soniox:webhook": "tsx scripts/soniox-webhook-test.ts",
    "prompt:test": "tsx scripts/prompt-test.ts",
    "prompt:test:f4": "tsx scripts/prompt-test.ts --f4",
    "data:prepare": "tsx scripts/prepare-test-data.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "transcript:smoke": "tsx scripts/transcript-smoke.ts",
    "sheets:smoke": "tsx scripts/sheets-smoke.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "dotenv": "^17.4.2",
    "googleapis": "^171.4.0",
    "grammy": "^1.30.0",
    "mime-types": "^3.0.2",
    "pino": "^9.5.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/mime-types": "^3.0.1",
    "@types/node": "^22.10.0",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  }
}
